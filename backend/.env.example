# ───────────────────────────────────────────────
# Idealstampa Backend - variabili d'ambiente
# Copiare questo file in .env e valorizzarlo
# ───────────────────────────────────────────────

# App
NODE_ENV=development
PORT=5000
LOG_LEVEL=info
BODY_LIMIT=50mb

# CORS (lista separata da virgole)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://www.idealstampa.com,https://idealstampa.com

# Rate limit endpoint /api/preventivo
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=10

# Upload file preventivi
UPLOAD_DIR=uploads/
UPLOAD_MAX_SIZE=26214400

# SMTP (Aruba di default)
SMTP_HOST=smtp.aruba.it
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@idealstampa.com
SMTP_PASS=
SMTP_CONN_TIMEOUT=10000
SMTP_GREETING_TIMEOUT=5000
SMTP_SOCKET_TIMEOUT=10000

# Email
COMPANY_EMAIL=info@idealstampa.com
EMAIL_FROM_NAME=Idealstampa

# Google Places (recensioni). Se vuote si usa il fallback
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
GOOGLE_CACHE_MS=21600000

# MongoDB — lasciare vuoto per disabilitare (l'app funziona comunque)
# In docker-compose: MONGO_URI viene impostata automaticamente verso il service 'mongo'
# Dev locale (senza docker): mongodb://localhost:27017
# Atlas: mongodb+srv://user:pass@cluster/...
MONGO_URI=
MONGO_DB_NAME=idealstampa
MONGO_TIMEOUT_MS=5000

# Credenziali MongoDB per docker-compose (cambia la password in produzione!)
MONGO_ROOT_USER=idealstampa
MONGO_ROOT_PASS=changeme

# ───────────────────────────────────────────────
# Admin Portal / Auth
# ───────────────────────────────────────────────
# JWT_SECRET: stringa random lunga (min 32 caratteri).
# Generala con:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=2h

# Rate limit login (tentativi per IP)
LOGIN_RATE_WINDOW_MS=900000
LOGIN_RATE_MAX=5

# Lockout account dopo N tentativi falliti
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MS=900000

# bcrypt cost (12 è un buon default; più alto = più lento + sicuro)
BCRYPT_ROUNDS=12

# Seed primo admin (usato solo da `npm run seed:admin`)
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_ROLE=superadmin
# ADMIN_FORCE_RESET=true   # decommenta per resettare la password di un admin esistente
