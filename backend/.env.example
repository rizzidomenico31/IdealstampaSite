# ───────────────────────────────────────────────
# Idealstampa Backend - variabili d'ambiente
# Copiare questo file in .env e valorizzarlo
# ───────────────────────────────────────────────

# App
NODE_ENV=development
PORT=5000
LOG_LEVEL=info
BODY_LIMIT=50mb

# CORS (lista separata da virgole)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://www.idealstampa.com,https://idealstampa.com

# Rate limit endpoint /api/preventivo
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=10

# Upload file preventivi
UPLOAD_DIR=uploads/
UPLOAD_MAX_SIZE=26214400

# SMTP (Aruba di default)
SMTP_HOST=smtp.aruba.it
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@idealstampa.com
SMTP_PASS=
SMTP_CONN_TIMEOUT=10000
SMTP_GREETING_TIMEOUT=5000
SMTP_SOCKET_TIMEOUT=10000

# Email
COMPANY_EMAIL=info@idealstampa.com
EMAIL_FROM_NAME=Idealstampa

# Google Places (recensioni). Se vuote si usa il fallback
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
GOOGLE_CACHE_MS=21600000

# MongoDB — lasciare vuoto per disabilitare (l'app funziona comunque)
# Esempio: mongodb://localhost:27017  oppure  mongodb+srv://user:pass@cluster/...
MONGO_URI=
MONGO_DB_NAME=idealstampa
MONGO_TIMEOUT_MS=5000
